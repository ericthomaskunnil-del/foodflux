<!-- Header layout partial — navbar + head -->
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description"
    content="Localised Food Surplus Distribution System — Connecting donors with volunteers to reduce food waste">
  <title>
    <%= typeof title !=='undefined' ? title : 'Food Flux' %>
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <!-- Leaflet Maps CSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
</head>

<body>
  <!-- Silk WebGL Background -->
  <div class="silk-wrapper" data-speed="5" data-scale="1" data-color="#7B7481" data-noise-intensity="1.5"
    data-rotation="0"></div>

  <!-- Toast notifications -->
  <% if (typeof success !=='undefined' && success) { %>
    <div class="toast toast-success" id="toast">
      <%= success %>
    </div>
    <% } %>
      <% if (typeof error !=='undefined' && error) { %>
        <div class="toast toast-error" id="toast">
          <%= error %>
        </div>
        <% } %>

          <!-- Navigation -->
          <nav class="navbar">
            <div class="nav-container">
              <a href="/" class="nav-logo">
                <span class="logo-icon">🍽️</span>
                <span class="logo-text">Food Flux</span>
              </a>
              <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
                <span></span><span></span><span></span>
              </button>
              <div class="nav-menu" id="navMenu">
                <% if (typeof user !=='undefined' && user) { %>
                  <a href="/dashboard" class="nav-link">Impact</a>
                  <a href="/<%= user.role %>" class="nav-link">Dashboard</a>
                  <% if (user.role==='admin' ) { %>
                    <a href="/admin/analytics" class="nav-link">Analytics</a>
                    <% } %>
                      <% if (user.role==='volunteer' ) { %>
                        <a href="/volunteer/directory" class="nav-link">Directory</a>
                        <% } %>
                          <a href="/messages" class="nav-link">Messages</a>
                          <span class="nav-badge">
                            <%= user.role %>
                          </span>
                          <a href="/auth/logout" class="nav-link nav-logout">Logout</a>
                          <% } else { %>
                            <a href="/" class="nav-link">Home</a>
                            <a href="/dashboard" class="nav-link">Impact Dashboard</a>
                            <a href="/auth/login" class="nav-link">Login</a>
                            <% } %>
                              <button class="theme-toggle" id="themeToggle" title="Toggle Dark/Light Mode"
                                aria-label="Toggle Dark/Light Mode">
                                <span class="sun-icon">☀️</span>
                                <span class="moon-icon">🌙</span>
                              </button>
                              <% if (typeof user==='undefined' || !user) { %>
                                <a href="/auth/register" class="btn btn-nav">Get Started</a>
                                <% } %>
              </div>
            </div>
          </nav>