<%- include('../layout/header') %>

    <section class="dashboard">
        <div class="container">
            <div class="dashboard-header">
                <div>
                    <h1>Restaurant Directory</h1>
                    <p>Browse local donors and view their trust ratings and active listings.</p>
                </div>
                <a href="/volunteer" class="btn btn-secondary">Back to Dashboard</a>
            </div>

            <div class="listings-grid">
                <% if (donors && donors.length> 0) { %>
                    <% donors.forEach(donor=> { %>
                        <div class="card"
                            style="display: flex; flex-direction: column; height: 100%; border: 1px solid var(--border-color); overflow: hidden; padding: 0;">
                            <!-- Profile Image Header -->
                            <div
                                style="height: 150px; background-color: var(--border-color); background-image: url('<%= donor.profileImageUrl || 'https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=400&h=300&fit=crop' %>'); background-size: cover; background-position: center; position: relative;">
                                <div
                                    style="position: absolute; bottom: 10px; right: 10px; background: rgba(0,0,0,0.7); backdrop-filter: blur(4px); padding: 4px 10px; border-radius: 20px; font-weight: bold; display: flex; align-items: center; gap: 5px;">
                                    ⭐️ <%= donor.trustScore ? donor.trustScore.toFixed(1) : 'New' %>
                                        <span style="font-size: 0.8em; font-weight: normal; opacity: 0.8;">(<%=
                                                donor.ratingsCount || 0 %>)</span>
                                </div>
                            </div>

                            <!-- Content -->
                            <div style="padding: 20px; flex: 1; display: flex; flex-direction: column;">
                                <h3 style="margin: 0 0 5px; font-size: 1.3rem;">
                                    <%= donor.restaurantName || donor.name %>
                                </h3>
                                <p
                                    style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 15px; display: flex; align-items: center; gap: 5px;">
                                    📍 <%= donor.address || 'Location unknown' %>
                                </p>

                                <p style="font-size: 0.95rem; margin-bottom: 20px; flex: 1;">
                                    <%= donor.description || 'A generous donor committed to reducing food waste.' %>
                                </p>

                                <div
                                    style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border-color); padding-top: 15px;">
                                    <div>
                                        <span style="font-size: 0.85rem; color: var(--text-muted);">Active
                                            Listings</span>
                                        <h4 style="margin: 0; color: var(--primary-color); font-size: 1.2rem;">
                                            <%= donor.activeListingsCount || 0 %>
                                        </h4>
                                    </div>
                                    <a href="/volunteer" class="btn btn-sm btn-primary">View Listings</a>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="empty-state" style="grid-column: 1 / -1;">
                                    <span class="empty-icon">🏪</span>
                                    <h3>No Restaurants Found</h3>
                                    <p>There are currently no registered donors in the system.</p>
                                </div>
                                <% } %>
            </div>
        </div>
    </section>

    <%- include('../layout/footer') %>