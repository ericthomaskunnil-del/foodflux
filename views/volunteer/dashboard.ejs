<%- include('../layout/header') %>

    <section class="dashboard">
        <div class="container">
            <div class="dashboard-header">
                <div>
                    <h1>Volunteer Dashboard</h1>
                    <p>Find and pick up surplus food for distribution</p>
                </div>
            </div>

            <!-- Phase 3: Volunteer Verification Status -->
            <div class="card"
                style="margin-bottom: 2rem; background: var(--bg-glass); border: 1px solid var(--border-color);">
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 20px;">
                    <div>
                        <h2 style="font-size: 1.2rem; margin-bottom: 5px;">Verification Status</h2>
                        <p style="font-size: 0.9rem; color: var(--text-secondary);">Verified volunteers get priority for
                            urgent pickups.</p>
                    </div>
                    <div>
                        <% if (user.isVerifiedVolunteer) { %>
                            <span class="badge" style="background: #2ecc71; color: white; padding: 8px 16px;">🛡️
                                Verified Volunteer</span>
                            <% } else if (user.verificationStatus==='pending' ) { %>
                                <span class="badge" style="background: #f1c40f; color: black; padding: 8px 16px;">⏳
                                    Verification Pending</span>
                                <% } else { %>
                                    <form action="/volunteer/request-verification" method="POST">
                                        <button type="submit" class="btn btn-primary">Request Verification</button>
                                    </form>
                                    <% } %>
                    </div>
                </div>
            </div>

            <!-- Live Map Area -->
            <div class="card"
                style="margin-bottom: 2rem; padding: 0; overflow: hidden; border: 1px solid var(--border-color);">
                <div class="card-header"
                    style="border-bottom: 1px solid var(--border-color); background: rgba(0,0,0,0.2);">
                    <h2 style="font-size: 1.25rem;">Live Donation Map</h2>
                </div>
                <div id="volunteer-map" style="height: 400px; width: 100%; z-index: 1;"
                    data-listings="<%= JSON.stringify(availableListings) %>"></div>
            </div>

            <!-- Stats Cards -->
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-card-icon">📦</div>
                    <div class="stat-card-info">
                        <span class="stat-card-value">
                            <%= availableListings.length %>
                        </span>
                        <span class="stat-card-label">Available Now</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-icon">🚚</div>
                    <div class="stat-card-info">
                        <span class="stat-card-value">
                            <%= myPickups.filter(p=> p.status === 'accepted').length %>
                        </span>
                        <span class="stat-card-label">In Progress</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-icon">✅</div>
                    <div class="stat-card-info">
                        <span class="stat-card-value">
                            <%= myPickups.filter(p=> p.status === 'completed').length %>
                        </span>
                        <span class="stat-card-label">Completed</span>
                    </div>
                </div>
            </div>

            <!-- Available Listings -->
            <div class="card">
                <div class="card-header">
                    <h2>Available Food Listings</h2>
                </div>
                <% if (availableListings.length===0) { %>
                    <div class="empty-state">
                        <span class="empty-icon">🍃</span>
                        <h3>No available listings</h3>
                        <p>Check back later for new food surplus listings</p>
                    </div>
                    <% } else { %>
                        <div class="listings-grid">
                            <% availableListings.forEach(listing=> { %>
                                <div class="listing-card"
                                    style="<%= listing.isUrgent ? 'border: 2px solid red;' : '' %>">
                                    <div class="listing-card-header">
                                        <h3>
                                            <%= listing.foodName %>
                                        </h3>
                                        <div>
                                            <% if (listing.isUrgent) { %>
                                                <span class="badge"
                                                    style="background-color: red; color: white;">Urgent</span>
                                                <% } %>
                                                    <span class="badge badge-available">Available</span>
                                        </div>
                                    </div>
                                    <div class="listing-card-body">
                                        <div class="listing-detail">
                                            <span class="detail-icon">📦</span>
                                            <span>
                                                <%= listing.quantity %>
                                            </span>
                                        </div>
                                        <div class="listing-detail">
                                            <span class="detail-icon">📍</span>
                                            <span>
                                                <%= listing.location %>
                                            </span>
                                        </div>
                                        <div class="listing-detail">
                                            <span class="detail-icon">🕐</span>
                                            <span>Pickup: <%= listing.pickupTime %></span>
                                        </div>
                                        <div class="listing-detail">
                                            <span class="detail-icon">⏰</span>
                                            <span>Expires: <%= listing.expiryTime %></span>
                                        </div>

                                        <!-- Phase 3: Food Safety Info -->
                                        <div
                                            style="margin-top: 12px; padding-top: 12px; border-top: 1px dashed var(--border-color); font-size: 0.85rem;">
                                            <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 8px;">
                                                <span class="badge"
                                                    style="background: var(--bg-glass); border: 1px solid var(--border-color); color: var(--text-primary);">
                                                    <%= listing.foodType %>
                                                </span>
                                                <span class="badge"
                                                    style="background: var(--bg-glass); border: 1px solid var(--border-color); color: var(--text-primary);">
                                                    ❄️ <%= listing.storageMethod %>
                                                </span>
                                            </div>

                                            <% const prepared=new Date(listing.preparedTime); const
                                                hoursSincePrepared=(new Date() - prepared) / (1000 * 60 * 60); let
                                                isUnsafe=false; if (listing.storageMethod==='Room Temperature' &&
                                                hoursSincePrepared> 4) isUnsafe = true;
                                                if (listing.storageMethod === 'Refrigerated' && hoursSincePrepared > 24)
                                                isUnsafe = true;
                                                %>

                                                <p style="margin-bottom: 4px;"><strong>Prepared:</strong>
                                                    <%= prepared.toLocaleString([], {month: 'short' , day: 'numeric' ,
                                                        hour: '2-digit' , minute: '2-digit' }) %>
                                                </p>

                                                <% if (listing.allergens && listing.allergens.length> 0) { %>
                                                    <p style="margin-bottom: 4px; color: #d63031;"><strong>⚠️
                                                            Allergens:</strong>
                                                        <%= listing.allergens.join(', ') %></p>
                                            <% } %>

                                            <% if (isUnsafe) { %>
                                                <div class="badge" style="background: #fab1a0; color: #d63031; border: 1px solid #ff7675; display: block; text-align: center; margin-top: 8px;">
                                                    ⚠️ Food Safety Warning: Consuming after 4h at RT is risky
                                                </div>
                                            <% } %>
                                        </div>
                                        <% if (listing.description) { %>
                                            <p class="listing-description">
                                                <%= listing.description %>
                                            </p>
                                            <% } %>
                                                <div class="listing-donor">
                                                    <span>Posted by: <strong>
                                                            <%= listing.donor ? listing.donor.name : ' Unknown' %>
                                                            </strong></span>
                                        </div>
                                    </div>
                                    <div class="listing-card-footer">
                                        <form action="/volunteer/accept/<%= listing._id %>" method="POST"
                                            id="accept-<%= listing._id %>">
                                            <button type="button" class="btn btn-primary btn-full"
                                                onclick="confirmAction('Accept this pickup?', 'accept-<%= listing._id %>')">
                                                Accept Pickup
                                            </button>
                                        </form>
                                    </div>
                                </div>
                                <% }) %>
                        </div>
                        <% } %>
            </div>

            <!-- My Pickups -->
            <% if (myPickups.length> 0) { %>
                <div class="card">
                    <div class="card-header">
                        <h2>My Pickup History</h2>
                    </div>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Food</th>
                                    <th>Donor</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% myPickups.forEach(pickup=> { %>
                                    <tr>
                                        <td><strong>
                                                <%= pickup.listing ? pickup.listing.foodName : 'Deleted' %>
                                            </strong></td>
                                        <td>
                                            <%= pickup.donor ? pickup.donor.name : 'N/A' %>
                                        </td>
                                        <td>
                                            <span
                                                class="badge badge-<%= pickup.status === 'completed' ? 'completed' : 'picked' %>">
                                                <%= pickup.status.charAt(0).toUpperCase() + pickup.status.slice(1) %>
                                            </span>
                                        </td>
                                        <td>
                                            <%= new Date(pickup.createdAt).toLocaleDateString() %>
                                        </td>
                                        <td>
                                            <% if (pickup.status==='accepted' ) { %>
                                                <form action="/volunteer/collect/<%= pickup._id %>" method="POST"
                                                    id="collect-<%= pickup._id %>">
                                                    <button type="button" class="btn btn-sm btn-primary"
                                                        onclick="confirmAction('Mark as collected?', 'collect-<%= pickup._id %>')">
                                                        Mark Collected
                                                    </button>
                                                </form>
                                                <button type="button" class="btn btn-sm btn-nav"
                                                    style="margin-top: 5px;" onclick="openScanner('<%= pickup._id %>')">
                                                    🛡️ Secure Verify
                                                </button>
                                                <% } else { %>
                                                    <span class="text-muted">Verified ✓</span>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <% } %>
        </div>
    </section>

    <!-- QR Scanner Modal -->
    <div id="scannerModal" class="modal"
        style="display:none; position:fixed; z-index:10001; left:0; top:0; width:100%; height:100%; background: rgba(0,0,0,0.8); backdrop-filter: blur(8px);">
        <div class="card" style="position:relative; max-width:500px; margin: 50px auto; padding: 20px;">
            <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
                <h2>Scan Pickup QR</h2>
                <button onclick="closeScanner()" class="btn btn-sm btn-outline">&times;</button>
            </div>
            <div id="reader" style="width:100%; border-radius: var(--radius); overflow:hidden; margin: 20px 0;"></div>
            <div id="scanner-status" style="text-align:center; padding: 10px; color: var(--text-secondary);">
                Align the donor's QR code within the frame
            </div>
            <form id="manualVerifyForm" method="POST"
                style="margin-top:20px; border-top:1px solid var(--border-color); padding-top:20px;">
                <p style="margin-bottom:10px; font-size: 0.9rem;">Or enter code manually:</p>
                <div style="display:flex; gap:10px;">
                    <input type="text" name="pickupCode" id="manualCode" placeholder="HEX CODE" required
                        style="flex:1;">
                    <button type="submit" class="btn btn-primary">Verify</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Scanner Dependencies & Script -->
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script>
        let html5QrCode;
        let currentTransactionId;

        function openScanner(transactionId) {
            currentTransactionId = transactionId;
            document.getElementById('scannerModal').style.display = 'block';
            document.getElementById('manualVerifyForm').action = `/volunteer/verify-pickup/${transactionId}`;

            html5QrCode = new Html5Qrcode("reader");
            const config = { fps: 10, qrbox: { width: 250, height: 250 } };

            html5QrCode.start({ facingMode: "environment" }, config, onScanSuccess)
                .catch(err => {
                    console.error("Scanner start error:", err);
                    document.getElementById('scanner-status').innerHTML = "⚠️ Camera permisson required for scanning";
                });
        }

        function onScanSuccess(decodedText, decodedResult) {
            // Stop scanner
            html5QrCode.stop().then(() => {
                // Fill manual code field and submit form
                document.getElementById('manualCode').value = decodedText;
                document.getElementById('manualVerifyForm').submit();
            });
        }

        function closeScanner() {
            if (html5QrCode && html5QrCode.isScanning) {
                html5QrCode.stop().then(() => {
                    document.getElementById('scannerModal').style.display = 'none';
                });
            } else {
                document.getElementById('scannerModal').style.display = 'none';
            }
        }
    </script>


    <!-- Leaflet Map Initialization Script -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const mapEl = document.getElementById('volunteer-map');
            if (mapEl && typeof L !== 'undefined') {
                // Initialize map (default center somewhere typical, or dynamically calculated)
                // Let's use a default center, e.g., NYC, then fit bounds if markers exist
                const map = L.map('volunteer-map').setView([40.7128, -74.0060], 12);

                L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
                    subdomains: 'abcd',
                    maxZoom: 20
                }).addTo(map);

                // Parse available listings from data attribute
                const listingsRaw = JSON.parse(mapEl.dataset.listings || '[]');

                const bounds = [];

                listingsRaw.forEach(listing => {
                    // Try to get coords from listing directly, or fallback to donor coords
                    let lat, lng;
                    if (listing.locationCoords && listing.locationCoords.lat && listing.locationCoords.lng) {
                        lat = listing.locationCoords.lat;
                        lng = listing.locationCoords.lng;
                    } else if (listing.donor && listing.donor.locationCoords && listing.donor.locationCoords.lat && listing.donor.locationCoords.lng) {
                        lat = listing.donor.locationCoords.lat;
                        lng = listing.donor.locationCoords.lng;
                    }

                    if (lat && lng) {
                        const marker = L.marker([lat, lng]).addTo(map);

                        // Create popup content
                        const urgencyWarning = listing.isUrgent ? '<p style="margin: 0 0 5px; color: red; font-weight: bold;">🚨 URGENT: Expiring Soon!</p>' : '';
                        const popupContent = `
                            <div style="color: #333; font-family: 'Inter', sans-serif;">
                                <h4 style="margin: 0 0 5px; font-weight: 600;">${listing.foodName}</h4>
                                ${urgencyWarning}
                                <p style="margin: 0 0 5px; font-size: 0.9em;"><strong>Quantity:</strong> ${listing.quantity}</p>
                                <p style="margin: 0; font-size: 0.9em;"><strong>Pickup:</strong> ${listing.pickupTime}</p>
                            </div>
                        `;
                        marker.bindPopup(popupContent);
                        bounds.push([lat, lng]);
                    }
                });

                if (bounds.length > 0) {
                    map.fitBounds(bounds, { padding: [50, 50] });
                }
            }
        });
    </script>

    <!-- Socket.io connection -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const currentUserId = '<%= user.id %>';

        // Join realtime room
        socket.emit('joinRoom', currentUserId);

        socket.on('newMatch', (listing) => {
            // Show a floating toast notification
            const toast = document.createElement('div');
            toast.className = 'toast toast-success';
            toast.style.position = 'fixed';
            toast.style.bottom = '20px';
            toast.style.right = '20px';
            toast.style.zIndex = '9999';
            toast.innerHTML = `
                <strong>🔔 New Food Match!</strong><br>
                ${listing.foodName} (${listing.quantity}) is available nearby!<br>
                <button onclick="window.location.reload()" style="margin-top:10px; padding: 5px; background: white; color: var(--primary-color); border:none; border-radius:3px; cursor:pointer;">Refresh Map</button>
            `;
            document.body.appendChild(toast);
        });
    </script>

    <%- include('../layout/footer') %>