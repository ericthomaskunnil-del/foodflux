<%- include('../layout/header') %>

    <section class="dashboard">
        <div class="container">
            <div class="dashboard-header">
                <div>
                    <h1>
                        <%= listing ? 'Edit Listing' : 'Add Food Listing' %>
                    </h1>
                    <p>
                        <%= listing ? 'Update your food listing details' : 'Share your surplus food with the community'
                            %>
                    </p>
                </div>
                <a href="/donor" class="btn btn-outline">← Back</a>
            </div>

            <div class="card form-card">
                <form action="<%= listing ? '/donor/edit/' + listing._id : '/donor/add' %>" method="POST"
                    class="listing-form">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="foodName">Food Name *</label>
                            <input type="text" id="foodName" name="foodName"
                                placeholder="e.g. Biryani, Sandwiches, Fruit Platter"
                                value="<%= listing ? listing.foodName : '' %>" required>
                        </div>
                        <div class="form-group">
                            <label for="quantity">Quantity *</label>
                            <input type="text" id="quantity" name="quantity" placeholder="e.g. 25 servings, 10 kg"
                                value="<%= listing ? listing.quantity : '' %>" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="pickupTime">Pickup Time *</label>
                            <input type="text" id="pickupTime" name="pickupTime" placeholder="e.g. 6:00 PM - 8:00 PM"
                                value="<%= listing ? listing.pickupTime : '' %>" required>
                        </div>
                        <div class="form-group">
                            <label for="expiryTime">Expiry Time *</label>
                            <input type="text" id="expiryTime" name="expiryTime" placeholder="e.g. 10:00 PM Today"
                                value="<%= listing ? listing.expiryTime : '' %>" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="foodType">Food Type *</label>
                            <select id="foodType" name="foodType" required>
                                <option value="Veg" <%=(listing && listing.foodType==='Veg' ) ? 'selected' : '' %>>Veg
                                </option>
                                <option value="Non-Veg" <%=(listing && listing.foodType==='Non-Veg' ) ? 'selected' : ''
                                    %>>Non-Veg</option>
                                <option value="Mixed" <%=(listing && listing.foodType==='Mixed' ) ? 'selected' : '' %>
                                    >Mixed</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="servingsAvailable">Servings Available *</label>
                            <input type="number" id="servingsAvailable" name="servingsAvailable" min="1"
                                placeholder="Number of people it can feed"
                                value="<%= listing ? listing.servingsAvailable : '' %>" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="preparedTime">Prepared Time *</label>
                            <input type="datetime-local" id="preparedTime" name="preparedTime"
                                value="<%= (listing && listing.preparedTime) ? new Date(listing.preparedTime.getTime() - listing.preparedTime.getTimezoneOffset() * 60000).toISOString().slice(0, 16) : '' %>"
                                required>
                        </div>
                        <div class="form-group">
                            <label for="storageMethod">Storage Method *</label>
                            <select id="storageMethod" name="storageMethod" required>
                                <option value="Room Temperature" <%=(listing &&
                                    listing.storageMethod==='Room Temperature' ) ? 'selected' : '' %>>Room Temperature
                                </option>
                                <option value="Refrigerated" <%=(listing && listing.storageMethod==='Refrigerated' )
                                    ? 'selected' : '' %>>Refrigerated</option>
                                <option value="Frozen" <%=(listing && listing.storageMethod==='Frozen' ) ? 'selected'
                                    : '' %>>Frozen</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="allergens">Allergens (Optional, comma separated)</label>
                        <input type="text" id="allergens" name="allergens" placeholder="e.g. Nuts, Dairy, Gluten"
                            value="<%= (listing && listing.allergens) ? listing.allergens.join(', ') : '' %>">
                    </div>

                    <div class="form-group">
                        <label for="location">Pickup Location *</label>
                        <input type="text" id="location" name="location" placeholder="Full address for pickup"
                            value="<%= listing ? listing.location : '' %>" required>
                    </div>

                    <div class="form-group">
                        <label for="description">Description (Optional)</label>
                        <textarea id="description" name="description" rows="3"
                            placeholder="Additional details about the food, packaging, etc."><%= listing ? listing.description : '' %></textarea>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">
                            <%= listing ? 'Update Listing' : 'Add Listing' %>
                        </button>
                        <a href="/donor" class="btn btn-outline">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <%- include('../layout/footer') %>