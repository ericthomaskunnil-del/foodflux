<%- include('../layout/header') %>

    <section class="dashboard">
        <div class="container">
            <div class="dashboard-header">
                <div>
                    <h1>Donor Dashboard</h1>
                    <p>Manage your food surplus listings</p>
                </div>
                <a href="/donor/add" class="btn btn-primary">+ Add Listing</a>
            </div>

            <!-- Stats Cards -->
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-card-icon">📋</div>
                    <div class="stat-card-info">
                        <span class="stat-card-value">
                            <%= listings.length %>
                        </span>
                        <span class="stat-card-label">Total Listings</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-icon">✅</div>
                    <div class="stat-card-info">
                        <span class="stat-card-value">
                            <%= listings.filter(l=> l.status === 'available').length %>
                        </span>
                        <span class="stat-card-label">Available</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-icon">🚚</div>
                    <div class="stat-card-info">
                        <span class="stat-card-value">
                            <%= listings.filter(l=> l.status === 'picked').length %>
                        </span>
                        <span class="stat-card-label">Being Picked</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-icon">🎉</div>
                    <div class="stat-card-info">
                        <span class="stat-card-value">
                            <%= listings.filter(l=> l.status === 'completed').length %>
                        </span>
                        <span class="stat-card-label">Completed</span>
                    </div>
                </div>
            </div>

            <!-- Listings Table -->
            <div class="card">
                <div class="card-header">
                    <h2>Your Listings</h2>
                </div>
                <% if (listings.length===0) { %>
                    <div class="empty-state">
                        <span class="empty-icon">📭</span>
                        <h3>No listings yet</h3>
                        <p>Start by adding your first food surplus listing</p>
                        <a href="/donor/add" class="btn btn-primary">Add Listing</a>
                    </div>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Food</th>
                                        <th>Quantity</th>
                                        <th>Location</th>
                                        <th>Pickup Time</th>
                                        <th>Status</th>
                                        <th>Approved</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% listings.forEach(listing=> { %>
                                        <tr>
                                            <td><strong>
                                                    <%= listing.foodName %>
                                                        <% if (listing.isUrgent) { %>
                                                            <span
                                                                style="color: red; font-size: 0.8em; margin-left: 5px;">(Urgent)</span>
                                                            <% } %>
                                                </strong></td>
                                            <td>
                                                <%= listing.quantity %>
                                            </td>
                                            <td>
                                                <%= listing.location %>
                                            </td>
                                            <td>
                                                <%= listing.pickupTime %>
                                            </td>
                                            <td>
                                                <span class="badge badge-<%= listing.status %>">
                                                    <%= listing.status.charAt(0).toUpperCase() + listing.status.slice(1)
                                                        %>
                                                </span>
                                            </td>
                                            <td>
                                                <span
                                                    class="badge badge-<%= listing.approved ? 'available' : 'expired' %>">
                                                    <%= listing.approved ? 'Yes' : 'Pending' %>
                                                </span>
                                            </td>
                                            <td class="actions-cell">
                                                <% if (listing.status==='available' || listing.status==='expired' ) { %>
                                                    <a href="/donor/edit/<%= listing._id %>"
                                                        class="btn btn-sm btn-outline">Edit</a>
                                                    <form action="/donor/delete/<%= listing._id %>" method="POST"
                                                        style="display:inline;" id="del-<%= listing._id %>">
                                                        <button type="button" class="btn btn-sm btn-danger"
                                                            onclick="confirmAction('Delete this listing?', 'del-<%= listing._id %>')">Delete</button>
                                                    </form>
                                                    <div
                                                        style="font-size: 0.75rem; color: var(--text-muted); margin-top: 5px;">
                                                        QR code generates on pickup
                                                    </div>
                                                    <% } else { %>
                                                        <% } %>
                                                            <% if (listing.status==='picked' ) { %>
                                                                <a href="/donor/qr/<%= listing._id %>"
                                                                    class="btn btn-sm btn-nav">View QR</a>
                                                                <% } %>
                                                                    <% if (listing.status==='completed' ) { %>
                                                                        <span class="text-muted">Verified ✓</span>
                                                                        <% } %>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                        <% } %>
            </div>

            <!-- Recent Transactions -->
            <% if (transactions.length> 0) { %>
                <div class="card">
                    <div class="card-header">
                        <h2>Pickup Activity</h2>
                    </div>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Food</th>
                                    <th>Volunteer</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% transactions.forEach(t=> { %>
                                    <tr>
                                        <td>
                                            <%= t.listing ? t.listing.foodName : 'Deleted' %>
                                        </td>
                                        <td>
                                            <%= t.volunteer ? t.volunteer.name : 'N/A' %>
                                        </td>
                                        <td>
                                            <span
                                                class="badge badge-<%= t.status === 'completed' ? 'completed' : 'picked' %>">
                                                <%= t.status.charAt(0).toUpperCase() + t.status.slice(1) %>
                                            </span>
                                        </td>
                                        <td>
                                            <%= new Date(t.createdAt).toLocaleDateString() %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <% } %>
        </div>
    </section>

    <%- include('../layout/footer') %>